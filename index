<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Base de Conocimientos RAG - Loterías IA</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        tinka: {
                            green: '#00A859',
                            green_dark: '#007A40',
                            yellow: '#FFD100',
                            yellow_hover: '#E5BC00',
                            bg: '#F8FAFC',
                            card: '#FFFFFF',
                            text: '#334155',
                            text_muted: '#64748B'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Chosen Palette: Tinka Brand Inspired (Warm Neutral Background, Tinka Green, Tinka Yellow Accents, Slate Text) -->
    <!-- Application Structure Plan: Dynamic Knowledge Management Dashboard with tone customization, live CRUD operations for Q&A inputs, and real-time Chart.js metric updates. -->
    <!-- Visualization & Content Choices: 
         1. Dynamic Doughnut Chart (Chart.js): Visualizes current distribution of Q&A across categories.
         2. Interactive Accordions with Edit/Delete controls.
         3. Tone Modifier UI: Real-time adaptation of text responses based on selected bot personality (Entusiasta, Formal, Directo).
         4. Modal Form: Clean UI for adding/editing KB items with instant state reflection.
         CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

    <style>
        .chart-container { 
            position: relative; 
            width: 100%; 
            max-width: 500px; 
            margin-left: auto; 
            margin-right: auto; 
            height: 350px; 
            max-height: 400px; 
        }
        @media (min-width: 768px) { 
            .chart-container { height: 400px; } 
        }
        
        .accordion-content {
            transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
            max-height: 0;
            opacity: 0;
            overflow: hidden;
        }
        .accordion-content.open {
            max-height: 1200px;
            opacity: 1;
        }

        .modal-backdrop {
            background-color: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body class="bg-tinka-bg text-tinka-text font-sans antialiased min-h-screen flex flex-col">

    <!-- HEADER -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex flex-wrap items-center justify-between gap-4 py-2">
            <div class="flex items-center gap-3">
                <span class="text-3xl">🤖</span>
                <div>
                    <h1 class="text-xl font-bold text-tinka-green_dark leading-tight">Loterías IA</h1>
                    <p class="text-xs text-tinka-text_muted font-medium uppercase tracking-wider">Gestor RAG & Configurador de Tono</p>
                </div>
            </div>

            <!-- CONTROLES GLOBALES DE TONO Y ACCIÓN -->
            <div class="flex items-center gap-3 flex-wrap">
                <!-- Selector de Tono -->
                <div class="flex items-center gap-2 bg-slate-100 px-3 py-1.5 rounded-xl border border-slate-200">
                    <span class="text-base">🎭</span>
                    <label for="tone-select" class="text-xs font-bold text-slate-600 hidden sm:inline">Tono del Bot:</label>
                    <select id="tone-select" onchange="changeTone(this.value)" class="bg-white text-xs font-bold text-slate-800 py-1 px-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-tinka-green cursor-pointer">
                        <option value="ludico">🎉 Entusiasta (Lúdico)</option>
                        <option value="formal">🏛️ Formal (Institucional)</option>
                        <option value="directo">⚡ Directo (Sintético)</option>
                    </select>
                </div>

                <!-- Botón Agregar Pregunta -->
                <button onclick="openInputModal()" class="bg-tinka-green hover:bg-tinka-green_dark text-white text-xs font-bold px-4 py-2.5 rounded-xl shadow-sm transition-all duration-200 flex items-center gap-1.5 cursor-pointer">
                    <span>➕</span>
                    <span>Nueva Pregunta</span>
                </button>

                <!-- Botón Restablecer KB -->
                <button onclick="resetDefaultKB()" title="Restablecer datos originales" class="bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 border border-gray-200 text-xs font-medium px-3 py-2.5 rounded-xl transition-all cursor-pointer">
                    <span>🔄</span>
                </button>
            </div>
        </div>
    </header>

    <!-- NOTIFICACIÓN TIPO TOAST -->
    <div id="toast-notification" class="fixed bottom-5 right-5 z-50 transform translate-y-20 opacity-0 transition-all duration-300 bg-slate-900 text-white text-xs font-medium px-4 py-3 rounded-xl shadow-2xl flex items-center gap-2 border border-slate-700">
        <span id="toast-icon">✅</span>
        <span id="toast-message">Cambio guardado exitosamente</span>
    </div>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col lg:flex-row gap-8">
        
        <!-- BARRA LATERAL -->
        <aside class="w-full lg:w-1/3 xl:w-1/4 shrink-0">
            <!-- NAVEGACIÓN POR CATEGORÍAS -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mb-6">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="text-base font-bold text-tinka-green_dark">Categorías RAG</h2>
                    <span id="kb-total-count" class="bg-tinka-yellow text-tinka-text text-xs font-extrabold px-2 py-0.5 rounded-full">0 inputs</span>
                </div>
                <p class="text-xs text-tinka-text_muted mb-4">
                    Selecciona una categoría para revisar, modificar o estructurar sus preguntas asociadas.
                </p>
                <nav id="category-nav" class="flex flex-col gap-2">
                    <!-- Nav items dinámicos -->
                </nav>
            </div>
            
            <!-- TARJETA INFORMATIVA DEL TONO SELECCIONADO -->
            <div id="tone-info-card" class="bg-slate-900 text-white rounded-2xl p-5 shadow-md border border-slate-800 transition-all">
                <div class="flex items-center justify-between mb-2">
                    <h3 id="tone-info-title" class="font-bold text-sm text-tinka-yellow flex items-center gap-2">
                        🎉 Tono Entusiasta
                    </h3>
                    <span class="text-xs bg-slate-800 px-2 py-0.5 rounded text-slate-300 border border-slate-700">Prompt Activo</span>
                </div>
                <p id="tone-info-desc" class="text-xs text-slate-300 leading-relaxed">
                    Usa lenguaje lúdico, llamadas a la acción enérgicas, emojificación comercial y priorización de promociones cruzadas.
                </p>
            </div>
        </aside>

        <!-- ÁREA DE CONTENIDO PRINCIPAL -->
        <section id="main-content-area" class="w-full lg:w-2/3 xl:w-3/4 flex flex-col gap-6">
            <!-- Contenido dinámico -->
        </section>

    </main>

    <!-- MODAL DE FORMULARIO PARA AGREGAR / EDITAR INPUT -->
    <div id="input-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden modal-backdrop p-4 overflow-y-auto">
        <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 w-full max-w-xl overflow-hidden my-8">
            <div class="bg-slate-900 text-white px-6 py-4 flex items-center justify-between">
                <h3 id="modal-title" class="text-base font-bold flex items-center gap-2">
                    <span>➕</span> Agregar Nueva Pregunta a la KB
                </h3>
                <button onclick="closeInputModal()" class="text-slate-400 hover:text-white text-lg font-bold cursor-pointer">✕</button>
            </div>
            
            <form id="kb-form" onsubmit="handleFormSubmit(event)" class="p-6 space-y-4">
                <input type="hidden" id="edit-item-index" value="-1">
                <input type="hidden" id="edit-category-id" value="">

                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Categoría RAG:</label>
                    <select id="modal-category-select" class="w-full text-xs font-medium p-2.5 rounded-xl border border-slate-300 bg-white focus:outline-none focus:ring-2 focus:ring-tinka-green">
                        <!-- Categorías dinámicas -->
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Pregunta del Usuario (Input / Intent):</label>
                    <input type="text" id="modal-question" required placeholder="Ej: ¿Puedo recargar mi saldo con Yape?" class="w-full text-xs p-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-tinka-green">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Respuesta Base del Bot (Knowledge Base):</label>
                    <textarea id="modal-answer" rows="4" required placeholder="Escribe aquí la respuesta oficial..." class="w-full text-xs p-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-tinka-green"></textarea>
                    <p class="text-[10px] text-slate-400 mt-1">El tono seleccionado aplicará modificadores visuales y de redacción sobre esta respuesta base.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Texto del Enlace / CTA (Opcional):</label>
                        <input type="text" id="modal-link-text" placeholder="Ej: Recargar saldo aquí" class="w-full text-xs p-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-tinka-green">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">URL de Redirección (Opcional):</label>
                        <input type="url" id="modal-link-url" placeholder="https://www.latinka.com.pe/..." class="w-full text-xs p-2.5 rounded-xl border border-slate-300 focus:outline-none focus:ring-2 focus:ring-tinka-green">
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-100 flex items-center justify-end gap-3">
                    <button type="button" onclick="closeInputModal()" class="px-4 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition cursor-pointer">
                        Cancelar
                    </button>
                    <button type="submit" class="px-5 py-2 text-xs font-bold bg-tinka-green hover:bg-tinka-green_dark text-white rounded-xl shadow-sm transition cursor-pointer">
                        Guardar en KB
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-white border-t border-gray-200 mt-auto py-6">
        <div class="max-w-7xl mx-auto px-4 text-center text-sm text-tinka-text_muted">
            Diseñado para la experiencia omnicanal de La Tinka. Motor RAG con edición dinámica y cambio de tono.
        </div>
    </footer>

    <script>
        // CONFIGURACIÓN DE BASE DE DATOS INICIAL
