                    }
                ]
            },
            compras: {
                id: 'compras',
                icon: '💳',
                title: 'Compras y Billetera',
                desc: 'Información transaccional sobre costos, recargas y métodos de pago aceptados.',
                type: 'category',
                items: [
                    {
