                        a: "Recarga rápido y seguro con tus tarjetas (Visa/Mastercard) o usando tus billeteras digitales favoritas: <strong>Yape, Plin, PagoEfectivo, o tu banca móvil</strong>. ¡Recuerda que tu primera recarga puede traer bonos adicionales!",
                        linkText: "Recargar saldo aquí",
                        linkUrl: "https://www.latinka.com.pe/p/mi-cuenta.html"
                    }
                ]
            },
            premios: {
                id: 'premios',
                icon: '🏆',
                title: 'Premios y Cobro',
                desc: 'Flujos de derivación para gestionar la ansiedad post-sorteo y facilitar el cobro seguro.',
                type: 'category',
                items: [
                    {
                        q: "¿Cómo cobro mi premio si gané?",
                        a: "¡Felicidades!<br><br><strong>Premios menores:</strong> Se abonan directamente como saldo en tu cuenta web para seguir jugando, o puedes solicitar un retiro a tu cuenta bancaria o tarjeta.<br><br><strong>Premios mayores:</strong> Se gestionan de forma segura previa validación de identidad.",
                        linkText: "Gestionar mi cobro vía Tinkanet",
                        linkUrl: "https://www.latinka.com.pe/p/cobro-premios.html"
                    }
                ]
            },
            responsable: {
                id: 'responsable',
                icon: '🛡️',
                title: 'Juego Responsable',
                desc: 'Directrices éticas para detectar y ayudar a usuarios con patrones de riesgo.',
                type: 'category',
                items: [
                    {
                        q: "Siento que estoy jugando demasiado, ¿pueden ayudarme?",
                        a: "Sí, tu bienestar es nuestra prioridad. Puedes establecer límites de depósito, tiempo de juego o solicitar autoexclusión desde tu perfil en la sección de 'Juego Responsable'.",
                        linkText: "Configurar mis límites",
                        linkUrl: "https://www.latinka.com.pe/p/juego-responsable.html"
                    }
                ]
            }
        };

        // CONFIGURACIÓN DE TONOS
        const toneConfigs = {
            ludico: {
                title: '🎉 Tono Entusiasta (Lúdico)',
                desc: 'Usa lenguaje enérgico, emojificación, llamado a la acción comercial y enfoque en la emoción de ganar.',
                badgeText: 'Tono: Entusiasta',
                badgeClass: 'bg-amber-100 text-amber-800 border-amber-300',
                transformText: (text) => text // Mantiene el formato alegre original
            },
            formal: {
                title: '🏛️ Tono Formal (Institucional)',
                desc: 'Elimina exclamaciones excesivas y lenguaje informal. Enfoque técnico, preciso y corporativo.',
                badgeText: 'Tono: Formal',
                badgeClass: 'bg-slate-100 text-slate-800 border-slate-300',
                transformText: (text) => {
                    return text
                        .replace(/¡/g, '')
                        .replace(/!/g, '.')
                        .replace(/rapidísimo/gi, 'sencillo y directo')
                        .replace(/Felicidades/gi, 'Estimado usuario');
                }
            },
            directo: {
                title: '⚡ Tono Directo (Sintético)',
                desc: 'Proporciona datos concisos, resúmenes directos y minimiza texto decorativo para respuestas rápidas.',
                badgeText: 'Tono: Directo',
                badgeClass: 'bg-blue-100 text-blue-800 border-blue-300',
                transformText: (text) => {
                    return text
                        .replace(/¡Siempre tenemos beneficios para potenciar tu suerte!/gi, 'Promociones activas:')
                        .replace(/¡Son chances extra!/gi, 'Modalidades de ganancia adicional:');
                }
            }
        };

        let kbData = {};
        let currentTone = 'ludico';
        let currentCategoryKey = 'overview';
        let currentChart = null;

        // INICIALIZACIÓN DE LA APP
        function initApp() {
            loadSavedData();
            renderNavigation();
            updateToneUI();
            loadContent(currentCategoryKey);
        }

        function loadSavedData() {
            const savedData = localStorage.getItem('tinka_kb_data');
            if (savedData) {
                try {
                    kbData = JSON.parse(savedData);
                } catch (e) {
                    kbData = JSON.parse(JSON.stringify(defaultKbData));
                }
            } else {
                kbData = JSON.parse(JSON.stringify(defaultKbData));
            }

            const savedTone = localStorage.getItem('tinka_kb_tone');
            if (savedTone && toneConfigs[savedTone]) {
                currentTone = savedTone;
                document.getElementById('tone-select').value = currentTone;
            }
        }

        function saveData() {
            localStorage.setItem('tinka_kb_data', JSON.stringify(kbData));
            localStorage.setItem('tinka_kb_tone', currentTone);
            updateTotalCount();
        }

        function resetDefaultKB() {
            if (confirm("¿Estás seguro de restablecer toda la Base de Conocimientos a los datos originales de La Tinka?")) {
                kbData = JSON.parse(JSON.stringify(defaultKbData));
                saveData();
                renderNavigation();
                loadContent(currentCategoryKey);
                showToast("✅ Base de Conocimientos restablecida");
            }
        }

        function updateTotalCount() {
            let total = 0;
            Object.keys(kbData).forEach(k => {
                if (kbData[k].type === 'category' && kbData[k].items) {
                    total += kbData[k].items.length;
                }
            });
            document.getElementById('kb-total-count').textContent = `${total} inputs`;
        }

        // CAMBIO DE TONO
        function changeTone(newTone) {
            currentTone = newTone;
            saveData();
            updateToneUI();
            loadContent(currentCategoryKey);
            showToast(`🎭 Tono cambiado a: ${toneConfigs[newTone].title}`);
        }

        function updateToneUI() {
            const config = toneConfigs[currentTone];
            document.getElementById('tone-info-title').textContent = config.title;
            document.getElementById('tone-info-desc').textContent = config.desc;
        }

        // RENDERIZADO DE NAVEGACIÓN
        function renderNavigation() {
            const nav = document.getElementById('category-nav');
            let html = '';
            
            Object.keys(kbData).forEach(key => {
                const item = kbData[key];
                const itemCount = item.items ? item.items.length : 0;
                
                html += `
                    <button onclick="loadContent('${key}')" id="nav-btn-${key}" class="nav-btn w-full text-left flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-200 hover:bg-gray-50 border border-transparent hover:border-gray-200 cursor-pointer">
                        <div class="flex items-center gap-3">
                            <span class="text-xl">${item.icon}</span>
                            <span class="font-semibold text-xs text-tinka-text">${item.title}</span>
                        </div>
                        ${item.type === 'category' ? `<span class="text-[10px] bg-slate-100 text-slate-500 font-bold px-2 py-0.5 rounded-full">${itemCount}</span>` : ''}
                    </button>
                `;
            });
            nav.innerHTML = html;
            updateTotalCount();
        }

        // CARGAR CONTENIDO
        function loadContent(key) {
            currentCategoryKey = key;
            
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('bg-tinka-green', 'text-white', 'border-tinka-green', 'shadow-sm', 'hover:bg-tinka-green');
                btn.classList.add('hover:bg-gray-50');
                const title = btn.querySelector('.font-semibold');
                if(title) title.classList.remove('text-white');
            });
            
            const activeBtn = document.getElementById(`nav-btn-${key}`);
            if(activeBtn) {
                activeBtn.classList.remove('hover:bg-gray-50');
                activeBtn.classList.add('bg-tinka-green', 'border-tinka-green', 'shadow-sm');
                const title = activeBtn.querySelector('.font-semibold');
                if(title) title.classList.add('text-white');
            }

            const area = document.getElementById('main-content-area');
            const data = kbData[key];

            if (data.type === 'dashboard') {
                renderDashboard(area, data);
            } else {
                renderCategory(area, data, key);
            }
        }

        // DASHBOARD RESUMEN
        function renderDashboard(container, data) {
            let html = `
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
                    <div class="mb-6 border-b border-gray-100 pb-4 flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-bold text-tinka-text flex items-center gap-2">
                                <span>${data.icon}</span> ${data.title}
                            </h2>
                            <p class="text-xs text-tinka-text_muted mt-1">${data.desc}</p>
                        </div>
                        <span class="text-xs font-bold px-3 py-1 rounded-full border ${toneConfigs[currentTone].badgeClass}">
                            ${toneConfigs[currentTone].badgeText}
                        </span>
                    </div>
                    
                    <div class="w-full">
                        <div class="chart-container">
                            <canvas id="kbChart"></canvas>
                        </div>
                    </div>
                    
                    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="bg-tinka-bg p-4 rounded-xl border border-gray-100">
                            <div class="text-[10px] text-tinka-text_muted uppercase font-bold tracking-wider mb-1">Métrica Clave</div>
                            <div class="text-base font-bold text-tinka-green_dark">Configuración de Tono Activa</div>
                            <p class="text-xs text-slate-600 mt-1">${toneConfigs[currentTone].desc}</p>
                        </div>
                        <div class="bg-tinka-bg p-4 rounded-xl border border-gray-100">
                            <div class="text-[10px] text-tinka-text_muted uppercase font-bold tracking-wider mb-1">Capacidad RAG</div>
                            <div class="text-base font-bold text-tinka-green_dark">Edición & Inserción en Vivo</div>
                            <p class="text-xs text-slate-600 mt-1">Puedes agregar nuevos inputs o editar los existentes desde el botón "+ Nueva Pregunta".</p>
                        </div>
                    </div>
                </div>
            `;
            container.innerHTML = html;
            initChart();
        }

        function initChart() {
            const ctx = document.getElementById('kbChart').getContext('2d');
            if (currentChart) currentChart.destroy();

            const labels = [];
            const dataPoints = [];
            const colors = ['#00A859', '#FFD100', '#3B82F6', '#8B5CF6', '#EC4899', '#10B981', '#F59E0B'];

            Object.keys(kbData).forEach(key => {
                if (kbData[key].type === 'category') {
                    labels.push(kbData[key].title);
                    dataPoints.push(kbData[key].items ? kbData[key].items.length : 0);
                }
            });

            currentChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: dataPoints,
                        backgroundColor: colors.slice(0, labels.length),
                        borderWidth: 0,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 15, font: { family: 'Inter', size: 12 } }
                        },
                        tooltip: {
                            callbacks: {
                                label: (ctx) => ` ${ctx.label}: ${ctx.raw} Entradas activas`
                            },
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            padding: 10,
                            cornerRadius: 8
                        }
                    },
                    cutout: '65%'
                }
            });
        }

        // RENDERIZADO DE CATEGORÍAS
        function renderCategory(container, data, categoryKey) {
            const toneTransform = toneConfigs[currentTone].transformText;

            let html = `
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
                    <div class="mb-6 border-b border-gray-100 pb-4 flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-xl font-bold text-tinka-text flex items-center gap-2">
                                <span>${data.icon}</span> ${data.title}
                            </h2>
                            <p class="text-xs text-tinka-text_muted mt-1">${data.desc}</p>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-bold px-3 py-1 rounded-full border ${toneConfigs[currentTone].badgeClass}">
                                ${toneConfigs[currentTone].badgeText}
                            </span>
                            <button onclick="openInputModal('${categoryKey}')" class="bg-tinka-green hover:bg-tinka-green_dark text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-sm transition flex items-center gap-1 cursor-pointer">
                                <span>➕</span> <span>Agregar aquí</span>
                            </button>
                        </div>
                    </div>
                    
                    <div class="space-y-4">
            `;

            if (!data.items || data.items.length === 0) {
                html += `
                    <div class="p-8 text-center bg-gray-50 rounded-xl border border-dashed border-gray-200">
                        <span class="text-3xl block mb-2">📭</span>
                        <p class="text-xs text-slate-500 font-medium">No hay preguntas registradas en esta categoría aún.</p>
                        <button onclick="openInputModal('${categoryKey}')" class="mt-3 text-xs font-bold text-tinka-green hover:underline cursor-pointer">
                            + Agregar la primera pregunta
                        </button>
                    </div>
                `;
            } else {
                data.items.forEach((item, index) => {
                    const isPromocion = item.promos !== undefined;
                    const adaptedAnswer = toneTransform(item.a);

                    html += `
                        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white hover:border-gray-300 transition-all">
                            <div class="flex items-center justify-between p-4 bg-white border-b border-gray-100">
                                <button onclick="toggleAccordion(this)" class="flex-grow text-left focus:outline-none flex items-center justify-between pr-4 cursor-pointer">
                                    <span class="font-bold text-xs sm:text-sm text-tinka-text flex items-center gap-2">
                                        <span class="text-tinka-green font-bold">Q:</span>
                                        <span>${item.q}</span>
                                    </span>
                                    <span class="text-gray-400 transform transition-transform duration-300 ml-2">▼</span>
                                </button>
                                
                                <div class="flex items-center gap-1 shrink-0 bg-slate-50 p-1 rounded-lg border border-slate-100">
                                    <button onclick="openEditModal('${categoryKey}', ${index})" title="Editar pregunta" class="text-xs text-slate-500 hover:text-tinka-green px-2 py-1 rounded hover:bg-white transition cursor-pointer">
                                        ✏️
                                    </button>
                                    <button onclick="deleteItem('${categoryKey}', ${index})" title="Eliminar pregunta" class="text-xs text-slate-500 hover:text-red-600 px-2 py-1 rounded hover:bg-white transition cursor-pointer">
                                        🗑️
                                    </button>
                                </div>
                            </div>

                            <div class="accordion-content bg-tinka-bg">
                                <div class="p-5 text-xs text-tinka-text leading-relaxed">
                                    <div class="flex items-start gap-2 mb-3">
                                        <span class="text-tinka-green font-bold text-xs">A:</span>
                                        <div class="flex-grow">${adaptedAnswer}</div>
                                    </div>
                                    
                                    ${isPromocion ? renderPromos(item.promos) : ''}
                                    
                                    ${item.footerNote ? `<p class="mt-4 italic text-tinka-text_muted text-[11px]">${item.footerNote}</p>` : ''}
                                    ${item.footerLinkText ? renderLink(item.footerLinkText, item.footerLinkUrl, 'mt-3') : ''}
                                    ${item.linkText ? renderLink(item.linkText, item.linkUrl, 'mt-4') : ''}
                                </div>
                            </div>
                        </div>
                    `;
                });
            }

            html += `
                    </div>
                </div>
            `;
            container.innerHTML = html;
        }

        function renderPromos(promos) {
            let promoHtml = '<div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4 ml-4">';
            promos.forEach(p => {
                promoHtml += `
                    <div class="bg-white p-3.5 rounded-lg border border-gray-200 shadow-sm flex flex-col h-full">
                        <h4 class="font-bold text-tinka-green_dark mb-1 text-xs">${p.title}</h4>
                        <p class="text-[11px] text-tinka-text_muted mb-3 flex-grow">${p.desc}</p>
                        ${renderLink(p.linkText, p.linkUrl, '', 'text-[11px]')}
                    </div>
                `;
            });
            promoHtml += '</div>';
            return promoHtml;
        }

        function renderLink(text, url, extraClasses = '', textClasses = 'text-xs') {
            return `
                <div class="${extraClasses}">
                    <a href="${url}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 font-bold ${textClasses} transition-colors group">
                        <span>👉</span>
                        <span class="underline group-hover:no-underline">${text}</span>
                    </a>
                </div>
            `;
        }

        function toggleAccordion(btn) {
            const content = btn.parentElement.nextElementSibling;
            const icon = btn.querySelector('span:last-child');
            
            document.querySelectorAll('.accordion-content').forEach(el => {
                if(el !== content) {
                    el.classList.remove('open');
                    const otherIcon = el.previousElementSibling.querySelector('button span:last-child');
                    if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
                }
            });

            content.classList.toggle('open');
            if (content.classList.contains('open')) {
                icon.style.transform = 'rotate(180deg)';
            } else {
                icon.style.transform = 'rotate(0deg)';
            }
        }

        // OPERACIONES CRUD (MODAL Y FORMULARIO)
        function openInputModal(targetCategory = null) {
            populateCategorySelect();
            document.getElementById('edit-item-index').value = '-1';
            document.getElementById('edit-category-id').value = '';
            document.getElementById('modal-title').innerHTML = '<span>➕</span> Agregar Nueva Pregunta a la KB';
            document.getElementById('kb-form').reset();

            if (targetCategory && kbData[targetCategory]) {
                document.getElementById('modal-category-select').value = targetCategory;
            } else if (currentCategoryKey !== 'overview') {
                document.getElementById('modal-category-select').value = currentCategoryKey;
            }

            document.getElementById('input-modal').classList.remove('hidden');
        }

        function openEditModal(categoryKey, index) {
            const item = kbData[categoryKey].items[index];
            if (!item) return;

            populateCategorySelect();
            document.getElementById('modal-title').innerHTML = '<span>✏️</span> Editar Pregunta de la KB';
            document.getElementById('edit-item-index').value = index;
            document.getElementById('edit-category-id').value = categoryKey;

            document.getElementById('modal-category-select').value = categoryKey;
            document.getElementById('modal-question').value = item.q;
            document.getElementById('modal-answer').value = item.a;
            document.getElementById('modal-link-text').value = item.linkText || '';
            document.getElementById('modal-link-url').value = item.linkUrl || '';

            document.getElementById('input-modal').classList.remove('hidden');
        }

        function closeInputModal() {
            document.getElementById('input-modal').classList.add('hidden');
        }

        function populateCategorySelect() {
            const select = document.getElementById('modal-category-select');
            let html = '';
            Object.keys(kbData).forEach(k => {
                if (kbData[k].type === 'category') {
                    html += `<option value="${k}">${kbData[k].icon} ${kbData[k].title}</option>`;
                }
            });
            select.innerHTML = html;
        }

        function handleFormSubmit(event) {
            event.preventDefault();
            
            const categoryKey = document.getElementById('modal-category-select').value;
            const editIndex = parseInt(document.getElementById('edit-item-index').value);
            const origCategoryKey = document.getElementById('edit-category-id').value;

            const q = document.getElementById('modal-question').value.trim();
            const a = document.getElementById('modal-answer').value.trim();
            const linkText = document.getElementById('modal-link-text').value.trim();
            const linkUrl = document.getElementById('modal-link-url').value.trim();

            const newItem = { q, a };
            if (linkText) newItem.linkText = linkText;
            if (linkUrl) newItem.linkUrl = linkUrl;

            if (editIndex >= 0 && origCategoryKey) {
                if (origCategoryKey !== categoryKey) {
                    kbData[origCategoryKey].items.splice(editIndex, 1);
                    kbData[categoryKey].items.push(newItem);
                } else {
                    kbData[categoryKey].items[editIndex] = newItem;
                }
                showToast("✏️ Pregunta actualizada exitosamente");
            } else {
                if (!kbData[categoryKey].items) kbData[categoryKey].items = [];
                kbData[categoryKey].items.push(newItem);
                showToast("➕ Nueva pregunta añadida a la KB");
            }

            saveData();
            closeInputModal();
            renderNavigation();
            loadContent(categoryKey);
        }

        function deleteItem(categoryKey, index) {
            if (confirm("¿Estás seguro de eliminar esta pregunta de la Base de Conocimientos?")) {
                kbData[categoryKey].items.splice(index, 1);
                saveData();
                renderNavigation();
                loadContent(categoryKey);
                showToast("🗑️ Pregunta eliminada");
            }
        }

        function showToast(msg) {
            const toast = document.getElementById('toast-notification');
            document.getElementById('toast-message').textContent = msg;
            toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // Inicializar al cargar
        window.addEventListener('DOMContentLoaded', initApp);
    </script>
</body>
</html>
